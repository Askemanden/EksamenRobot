#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------

PROJECT_NAME           = "Arduino Project"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------

INPUT                  = .
RECURSIVE              = YES

FILE_PATTERNS          = *.ino
EXTENSION_MAPPING      = ino=C++

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html

#---------------------------------------------------------------------------
# LaTeX output
#---------------------------------------------------------------------------

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
USE_PDFLATEX           = YES

#---------------------------------------------------------------------------
# Graphs (optional but useful)
#---------------------------------------------------------------------------

HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

#---------------------------------------------------------------------------
# Misc
#---------------------------------------------------------------------------

FULL_PATH_NAMES        = NO
QUIET                  = NO
WARNINGS               = YES
